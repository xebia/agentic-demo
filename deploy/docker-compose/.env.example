# ============================================================
# Ticketing System — Docker Compose Environment Variables
# ============================================================
# Copy this file to .env and fill in the values below.
# .env is git-ignored and will not be committed.
# ============================================================

# --- SQL Server ---
SA_PASSWORD=Your_Strong_Password_123!
# Must meet SQL Server complexity requirements:
# 8+ chars, uppercase, lowercase, digit, special character

# --- Azure OpenAI (required for AI agents and chatbot) ---
# Leave blank to run without AI features (agents will log warnings)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4-turbo
