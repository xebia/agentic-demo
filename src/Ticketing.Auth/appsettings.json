{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AuthSettings": {
    "Issuer": "https://auth.ticketing.local",
    "Audience": "ticketing-api",
    "TokenLifetimeMinutes": 60,
    "ServiceAccountTokenLifetimeMinutes": 30
  },
  "ServiceAccounts": [
    {
      "ClientId": "triage-agent",
      "ClientSecret": "secret-for-triage",
      "DisplayName": "Triage Agent",
      "Roles": ["Agent", "HelpDesk"]
    },
    {
      "ClientId": "purchasing-agent",
      "ClientSecret": "secret-for-purchasing",
      "DisplayName": "Purchasing Agent",
      "Roles": ["Agent", "HelpDesk", "Approver"]
    },
    {
      "ClientId": "fulfillment-agent",
      "ClientSecret": "secret-for-fulfillment",
      "DisplayName": "Fulfillment Agent",
      "Roles": ["Agent", "HelpDesk"]
    },
    {
      "ClientId": "operations-agent",
      "ClientSecret": "secret-for-operations",
      "DisplayName": "Operations Agent",
      "Roles": ["Agent", "HelpDesk"]
    }
  ],
  "AllowedHosts": "*"
}
