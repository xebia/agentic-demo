{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "Information",
      "Ticketing.TriageAgent": "Information"
    }
  },
  "extensions": {
    "serviceBus": {
      "maxConcurrentCalls": 1,
      "autoCompleteMessages": true
    }
  }
}
