@using Ticketing.Web.Services.Auth
@inject NavigationManager Navigation
@inject AuthServiceClient AuthService

<div class="user-picker dropdown">
    <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-person-circle me-1"></i>
        <AuthorizeView>
            <Authorized>@context.User.Identity?.Name</Authorized>
            <NotAuthorized>Not Signed In</NotAuthorized>
        </AuthorizeView>
    </button>
    <ul class="dropdown-menu dropdown-menu-end">
        <li><h6 class="dropdown-header">Switch User (Demo)</h6></li>
        @if (users == null)
        {
            <li><span class="dropdown-item-text text-muted">Loading...</span></li>
        }
        else
        {
            @foreach (var user in users)
            {
                <li>
                    <a class="dropdown-item" href="@GetSwitchUserUrl(user)">
                        <div class="d-flex flex-column">
                            <span>@user.DisplayName</span>
                            <small class="text-muted">@string.Join(", ", user.Roles)</small>
                        </div>
                    </a>
                </li>
            }
        }
    </ul>
</div>

@code {
    private IReadOnlyList<MockUser>? users;

    protected override async Task OnInitializedAsync()
    {
        users = await AuthService.GetAvailableUsersAsync();
    }

    private string GetSwitchUserUrl(MockUser user)
    {
        return $"/auth/switch-user/{user.Id}";
    }
}
