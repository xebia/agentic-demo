@page "/auth/switch-user/{UserId}"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Ticketing.Web.Services.Auth
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject AuthServiceClient AuthService
@inject ILogger<SwitchUser> Logger

@* This is intentionally an SSR-only page (no @rendermode) to access HttpContext *@

@code {
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext == null)
        {
            // Should never happen for SSR pages
            Navigation.NavigateTo("/");
            return;
        }

        // Authenticate the user via the auth service
        // This demonstrates where real credential validation would occur
        Logger.LogInformation("Authenticating user {UserId} via auth service...", UserId);

        var tokenResponse = await AuthService.AuthenticateUserAsync(userId: UserId);
        if (tokenResponse == null)
        {
            // Authentication failed - redirect to home with error
            Logger.LogWarning("Authentication failed for user {UserId}", UserId);
            Navigation.NavigateTo("/?error=auth_failed");
            return;
        }

        Logger.LogInformation("User {UserId} authenticated successfully. Token expires at {ExpiresAt}",
            tokenResponse.Subject.Id,
            tokenResponse.ExpiresAt);

        // Create claims from the authenticated token response
        var claims = new List<Claim>
        {
            new(ClaimTypes.NameIdentifier, tokenResponse.Subject.Id),
            new(ClaimTypes.Email, tokenResponse.Subject.Email),
            new(ClaimTypes.Name, tokenResponse.Subject.DisplayName),
            // Store the JWT token as a claim for potential API calls
            new("jwt_token", tokenResponse.Token)
        };

        // Add role claims from the token response
        foreach (var role in tokenResponse.Subject.Roles)
        {
            claims.Add(new Claim(ClaimTypes.Role, role));
        }

        var identity = new ClaimsIdentity(claims, "MockAuth");
        var principal = new ClaimsPrincipal(identity);

        // Sign in using HttpContext cookie authentication
        await httpContext.SignInAsync("MockAuth", principal);

        // Redirect to home page
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
