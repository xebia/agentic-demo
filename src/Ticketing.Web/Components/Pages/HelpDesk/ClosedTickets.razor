@page "/helpdesk/closed"
@attribute [Authorize(Roles = UserRoles.HelpDesk)]

<PageTitle>Closed Tickets - Help Desk</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Closed Help Desk Tickets</h1>
    <a href="/helpdesk/open" class="btn btn-primary">
        <i class="bi bi-inbox"></i> View Open Tickets
    </a>
</div>

@if (_tickets == null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_tickets.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No closed tickets found.
    </div>
}
else
{
    <div class="mb-3 text-muted">
        Showing @_tickets.Count of @_tickets.TotalCount closed tickets
    </div>

    @foreach (var ticket in _tickets)
    {
        <TicketCard Ticket="ticket" ShowActions="false" />
    }
}

@code {
    [Inject]
    private IDataPortal<TicketList> _ticketListPortal { get; set; } = null!;

    private TicketList? _tickets;

    protected override async Task OnInitializedAsync()
    {
        var criteria = TicketListCriteria.ClosedHelpDeskTickets();
        _tickets = await _ticketListPortal.FetchAsync(criteria);
    }
}
