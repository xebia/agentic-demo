@* Shared ticket card component for displaying ticket information in lists *@

<div class="card ticket-card mb-2 @(IsSelected ? "border-primary" : "")">
    <div class="card-body py-2">
        <div class="d-flex justify-content-between align-items-start">
            <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="@Ticket.PriorityCssClass">@Ticket.Priority</span>
                    <span class="badge bg-secondary">@Ticket.Status.GetDisplayName()</span>
                    @if (Ticket.ParentTicketId != null)
                    {
                        <span class="badge bg-light text-dark">
                            <i class="bi bi-link-45deg"></i> @Ticket.ParentTicketId
                        </span>
                    }
                </div>
                <h6 class="card-title mb-1">
                    <a href="@($"tickets/{Ticket.TicketId}")" class="text-decoration-none text-dark">
                        @Ticket.TicketId - @Ticket.Title
                    </a>
                </h6>
                <p class="card-text text-muted small mb-0">
                    <i class="bi bi-person"></i> @Ticket.RequestorDisplayName
                    <span class="mx-2">•</span>
                    <i class="bi bi-clock"></i> @Ticket.TimeSinceCreation
                    @if (Ticket.AssignedQueue.HasValue)
                    {
                        <span class="mx-2">•</span>
                        <i class="bi bi-inbox"></i> @Ticket.AssignedQueue.Value.GetDisplayName()
                    }
                </p>
            </div>
            @if (ShowActions)
            {
                <div class="btn-group">
                    @if (OnClose.HasDelegate)
                    {
                        <button class="btn btn-sm btn-outline-success" @onclick="HandleClose" title="Close Ticket">
                            <i class="bi bi-check-lg"></i> Close
                        </button>
                    }
                    @if (OnApprove.HasDelegate)
                    {
                        <button class="btn btn-sm btn-outline-success" @onclick="HandleApprove" title="Approve">
                            <i class="bi bi-check-lg"></i> Approve
                        </button>
                    }
                    @if (OnReject.HasDelegate)
                    {
                        <button class="btn btn-sm btn-outline-danger" @onclick="HandleReject" title="Reject">
                            <i class="bi bi-x-lg"></i> Reject
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TicketInfo Ticket { get; set; } = null!;

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public bool ShowActions { get; set; } = true;

    [Parameter]
    public EventCallback<TicketInfo> OnClose { get; set; }

    [Parameter]
    public EventCallback<TicketInfo> OnApprove { get; set; }

    [Parameter]
    public EventCallback<TicketInfo> OnReject { get; set; }

    private async Task HandleClose() => await OnClose.InvokeAsync(Ticket);
    private async Task HandleApprove() => await OnApprove.InvokeAsync(Ticket);
    private async Task HandleReject() => await OnReject.InvokeAsync(Ticket);
}
